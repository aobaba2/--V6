rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required, immutable)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['free', 'pro', 'admin'])
    //   - createdAt: timestamp (required, immutable)
    //   - lastLogin: timestamp (required)
    //   - aiAnalysisCount: number (required)
    //   - mockTradingEnabled: boolean (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "yujianfei2016@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'aiAnalysisCount', 'mockTradingEnabled']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['free', 'pro', 'admin'] &&
             data.aiAnalysisCount is number &&
             data.mockTradingEnabled is bool;
    }

    match /users/{userId} {
      // Allow read/list only for owner or admin
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Allow create if owner and setting initial role to 'free'
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'free';
      
      // Allow update if owner (but cannot change role) or admin
      allow update: if (isOwner(userId) && 
                        isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role) || 
                      isAdmin();
    }
  }
}
